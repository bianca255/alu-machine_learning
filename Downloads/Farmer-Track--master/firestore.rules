rules_version = '2'; service cloud.firestore {   match /databases/{database}/documents {      // All user data is scoped under /users/{userId}/     match /users/{userId} {        // Only the authenticated user can access their own subtree       function isOwner() {         return request.auth != null && request.auth.uid == userId;       }        function isValidString(field) {         return field is string && field.size() > 0;       }        function isPositiveNumber(field) {         return field is number && field > 0;       }        // ΓöÇΓöÇ Seasons ΓöÇΓöÇ       match /seasons/{seasonId} {         allow read: if isOwner();         allow create: if isOwner()           && isValidString(request.resource.data.name)           && isValidString(request.resource.data.startDate)           && isValidString(request.resource.data.currency);         allow update: if isOwner();         allow delete: if isOwner();       }        // ΓöÇΓöÇ Crop Cycles ΓöÇΓöÇ       match /crops/{cropId} {         allow read: if isOwner();         allow create: if isOwner()           && isValidString(request.resource.data.seasonId)           && isValidString(request.resource.data.cropName)           && isValidString(request.resource.data.plantingDate)           && request.resource.data.status in ['planted', 'harvested', 'closed'];         allow update: if isOwner()           && request.resource.data.status in ['planted', 'harvested', 'closed'];         allow delete: if isOwner();       }        // ΓöÇΓöÇ Expenses ΓöÇΓöÇ       match /expenses/{expenseId} {         allow read: if isOwner();         allow create: if isOwner()           && isValidString(request.resource.data.cropCycleId)           && isValidString(request.resource.data.seasonId)           && isPositiveNumber(request.resource.data.amount)           && request.resource.data.category in [                'seed', 'fertilizer', 'pesticide', 'labor',                'transport', 'equipment', 'irrigation', 'other'              ];         allow update: if isOwner();         allow delete: if isOwner();       }        // ΓöÇΓöÇ Harvests ΓöÇΓöÇ       match /harvests/{harvestId} {         allow read: if isOwner();         allow create: if isOwner()           && isValidString(request.resource.data.cropCycleId)           && isValidString(request.resource.data.seasonId)           && request.resource.data.quantity is number           && request.resource.data.quantity >= 0;         allow update: if isOwner();         allow delete: if isOwner();       }        // ΓöÇΓöÇ Sales ΓöÇΓöÇ       match /sales/{saleId} {         allow read: if isOwner();         allow create: if isOwner()           && isValidString(request.resource.data.cropCycleId)           && isValidString(request.resource.data.seasonId)           && isPositiveNumber(request.resource.data.quantitySold)           && isPositiveNumber(request.resource.data.pricePerUnit)           && request.resource.data.buyerType in ['market', 'cooperative', 'individual', 'other']           && request.resource.data.paymentStatus in ['paid', 'unpaid', 'partial'];         allow update: if isOwner();         allow delete: if isOwner();       }     }      // Deny everything else by default     match /{document=**} {       allow read, write: if false;     }   } }